{
  "expo": {
    "name": "QuickExpenses",
    "slug": "quickexpenses",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "quickexpenses",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F9F9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quickexpenses.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9F9F9"
      },
      "package": "com.quickexpenses.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QuickExpenses to attach photos to your expense entries.",
          "cameraPermission": "Allow QuickExpenses to take photos for your expense entries."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1fcb188a-f028-4718-acde-bef40da9a74a"
      }
    },
    "owner": "zainydev"
  }
}
